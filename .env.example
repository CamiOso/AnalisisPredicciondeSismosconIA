# Environment Configuration Example
# Copia este archivo a .env y reemplaza con tus valores

# ==================== EMAIL ALERTS ====================
# Para usar el sistema de alertas por email
EMAIL_SENDER=your_email@gmail.com
EMAIL_PASSWORD=your_app_specific_password

# ==================== DATABASE ====================
# SQLite (por defecto)
DATABASE_URL=sqlite:///data/seismic.db

# PostgreSQL (opcional)
# DATABASE_URL=postgresql://user:password@localhost:5432/seismic_db
# POSTGRES_USER=seismic_user
# POSTGRES_PASSWORD=seismic_password

# ==================== API CONFIGURATION ====================
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=False
API_WORKERS=4

# ==================== STREAMLIT CONFIGURATION ====================
STREAMLIT_SERVER_HEADLESS=false
STREAMLIT_LOGGER_LEVEL=warning
STREAMLIT_CLIENT_SHOWERRORDETAILS=false

# ==================== LOGGING ====================
LOG_LEVEL=INFO
LOG_FILE=logs/seismic.log
LOG_MAX_SIZE=10485760
LOG_BACKUP_COUNT=5

# ==================== MONITORING ====================
ENABLE_PROMETHEUS=false
PROMETHEUS_PORT=8001

# ==================== SECURITY ====================
# JWT Secret para API
JWT_SECRET_KEY=your_secret_key_here_make_it_long_and_random

# CORS allowed origins
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8501"]

# ==================== MODEL CONFIGURATION ====================
SEQUENCE_LENGTH=30
LSTM_UNITS=64
EPOCHS=100
BATCH_SIZE=32

# ==================== ANOMALY DETECTION ====================
ANOMALY_CONTAMINATION=0.05
ANOMALY_METHOD=isolation_forest

# ==================== DATA ====================
DATA_DIR=data/
MODELS_DIR=models/
NOTEBOOKS_DIR=notebooks/

# ==================== FEATURES (Experimental) ====================
ENABLE_REAL_USGS_DATA=false
ENABLE_EMAIL_ALERTS=false
ENABLE_WEBHOOKS=false

# ==================== DEBUG ====================
DEBUG_MODE=false
VERBOSE_LOGGING=false
